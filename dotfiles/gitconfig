# vim: sts=2 sw=2 ts=2

[user]
  name = Vardan Pogosian
  email = vardan.pogosyan@gmail.com

[github]
  user = varp

[merge]
  branchdesc = true
  conflictStyle = zdiff3

[apply]
  whitespace = nowarn

[core]
  editor = vim
  autocrlf = input
  eol = lf
  excludesfile = ~/.gitignore
  pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    line-numbers = true

[alias]
  c         = commit
  co        = checkout
  ct        = checkout -t
  ci        = commit -v
  ca        = commit -av
  s         = status
  st        = status -sb
  sl        = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --abbrev=8
  ss        = log --pretty=format:'%Cgreen%h%Creset %Cblue[%ci]%Creset - %C(yellow)%d%Creset | %s - %C(bold blue)<%an>%Creset' --abbrev-commit --abbrev=8
  up        = pull --rebase
  track     = !git-track
  prune-all = !git-prune-all
  sync      = !git pull && git push
  r         = remote -v
  b         = branch -v
  rh        = reset --hard

[apply]
  whitespace = nowarn

[color]
  ui     = true
  branch = auto
  diff   = auto
  status = auto

[push]
  default = tracking

[pull]
  rebase = false

[gc]
  auto = 1

[url "ssh://git@github.com"]
  insteadOf = https://github.com
[url "ssh://git@bitbucket.org"]
  insteadof = https://bitbucket.org


[diff]
    colorMoved = default

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[push]
  autoSetupRemote = true
